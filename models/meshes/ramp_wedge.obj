# Solid triangular-prism ramp wedge.
# Rises along +x from (x=0,z=0) to (x=1,z=1); width y in [-0.5,0.5].
# Scale per-instance in the MJCF <mesh> tag (scale = run width rise).
v 0 -0.5 0
v 1 -0.5 0
v 1 -0.5 1
v 0 0.5 0
v 1 0.5 0
v 1 0.5 1
# slope (top walking surface)
f 1 3 6
f 1 6 4
# bottom
f 1 2 5
f 1 5 4
# tall vertical end (x=1)
f 2 3 6
f 2 6 5
# left side (y=-0.5)
f 1 2 3
# right side (y=0.5)
f 4 6 5
